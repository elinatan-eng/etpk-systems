{
  "id": "zo-skill",
  "name": "Zo Skill Runner",
  "description": "Call zo_skill.py to run Zo Computer automations, skills, or chats.",
  "entry": "python zo_skill.py",
  "modes": [
    {
      "id": "run-skill",
      "description": "Structured skill invocation by skill_id + JSON args.",
      "inputs": {
        "skill_id": {
          "type": "string",
          "required": true,
          "examples": ["receipts", "trading", "prospecting"],
          "pattern": "^[a-z0-9_-]+$"
        },
        "args": {
          "type": "object",
          "required": false,
          "default": {}
        }
      },
      "iam_scope": "skill:run",
      "risk_level": "medium",
      "deny_patterns": ["delete", "destroy", "drop", "rm -rf", "truncate", "shutdown"]
    },
    {
      "id": "run-chat",
      "description": "Send a chat-style request to Zo and return the response.",
      "inputs": {
        "message": {
          "type": "string",
          "required": true,
          "max_length": 4000
        },
        "model": {
          "type": "string",
          "required": false,
          "default": "vercel:minimax/minimax-m2.7"
        },
        "persona_id": {
          "type": "string",
          "required": false
        }
      },
      "iam_scope": "chat:send",
      "risk_level": "low",
      "deny_patterns": []
    }
  ],
  "deny_patterns": [
    { "pattern": "delete.*repo", "message": "Repo deletions are blocked." },
    { "pattern": "drop.*table", "message": "Database drop operations are blocked." },
    { "pattern": "rm -rf", "message": "Recursive force delete is blocked." },
    { "pattern": "payment.*send.*crypto", "message": "Direct crypto send is blocked — use approved payment workflows only." },
    { "pattern": "stripe.*refund.*force", "message": "Forced refunds require human approval." },
    { "pattern": "shutdown", "message": "Service shutdown requires explicit human ok." },
    { "pattern": "eval|exec.*\\(.*\\)", "message": "Arbitrary code execution is blocked." }
  ],
  "iam_scope": "skill:invoke",
  "risk_level": "medium",
  "version": "1.0"
}
